{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "mcp": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {}
    },
    "nuget": {
      "type": "stdio",
      "command": "nuget-mcp-server",
      "args": []
    }
  }
}
